{
  "version": "0.2.18",
  "license": "MIT",
  "name": "project-tool",
  "description": "a tool project to help build other project",
  "author": "MrWangJustToDo",
  "engines": {
    "node": ">=10"
  },
  "files": [
    "packages",
    "rollup.js",
    "rollup.d.ts",
    "request.js",
    "request.d.ts",
    "baseLint.js",
    "reactLint.js",
    "styleLint.js"
  ],
  "exports": {
    "./rollup": {
      "types": "./rollup.d.ts",
      "default": "./rollup.js"
    },
    "./request": {
      "types": "./request.d.ts",
      "default": "./request.js"
    },
    "./baseLint": "./baseLint.js",
    "./reactLint": "./reactLint.js",
    "./styleLint": "./styleLint.js"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build:packages": "ts-node ./build.ts",
    "dev:packages": "ts-node ./watch.ts",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "style": "stylelint --cache \"packages/**/*.(scss|css)\"",
    "style:fix": "pnpm run style --fix",
    "prettier": "prettier --ignore-path .prettierignore --write .",
    "clean": "pnpm -p -r -c exec rm -rf dist dev .cache tsconfig.tsbuildinfo",
    "purge": "pnpm -p -r -c exec rm -rf node_modules"
  },
  "dependencies": {
    "@eslint/js": "^9.28.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "axios": "^1.13.6",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lodash": "^4.17.23",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "tslib": "^2.8.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@project-tool/axios": "workspace: *",
    "@project-tool/eslint": "workspace: *",
    "@project-tool/rollup": "workspace: *",
    "@project-tool/stylelint": "workspace: *",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.3.3"
  }
}
